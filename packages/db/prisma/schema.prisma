generator client {
  provider     = "prisma-client"
  output       = "../prisma-generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id
  name               String
  email              String             @unique
  emailVerified      Boolean            @default(false)
  image              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  username           String?            @unique
  displayUsername    String?
  role               Role               @default(FINANCE)
  accounts           Account[]
  businessDocuments  BusinessDocument[]
  members            ChannelMember[]
  invoices           Invoice[]
  createdJobCards    JobCard[]          @relation("JobCardCreatedBy")
  journalEntries     JournalEntry[]
  messages           Message[]
  assignedOperations Operation[]        @relation("OperationOperator")
  qcLogs             QcLog[]            @relation("QcInspector")
  sessions           Session[]
  stockAdjustments   StockAdjustment[]  @relation("StockAdjustedBy")
  stockLedgers       StockLedger[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Channel {
  id          String          @id @default(uuid())
  name        String?
  isDM        Boolean         @default(false)
  dmKey       String?         @unique
  createdAt   DateTime        @default(now())
  lastMessage DateTime        @default(now())
  members     ChannelMember[]
  messages    Message[]

  @@map("channel")
}

model ChannelMember {
  userId    String
  channelId String
  joinedAt  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, channelId])
  @@map("channel_member")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("text")
  fileUrl   String?
  createdAt DateTime @default(now())
  senderId  String
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  sender    User     @relation(fields: [senderId], references: [id])

  @@map("message")
}

model ChartOfAccount {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  type         AccountType
  parentCode   String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  journalLines JournalLine[]

  @@map("chart_of_account")
}

model JournalEntry {
  id          String        @id @default(uuid())
  date        DateTime
  description String
  period      String
  createdAt   DateTime      @default(now())
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id])
  lines       JournalLine[]

  @@map("journal_entry")
}

model JournalLine {
  id             String         @id @default(uuid())
  journalEntryId String
  accountId      String
  amount         Float
  isDebit        Boolean
  description    String?
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@map("journal_line")
}

model FixedAsset {
  id                      String   @id @default(uuid())
  name                    String
  category                String
  acquisitionDate         DateTime
  usefulLifeMonths        Int
  acquisitionCost         Float
  monthlyDepreciation     Float
  accumulatedDepreciation Float    @default(0)
  bookValue               Float
  createdAt               DateTime @default(now())

  @@map("fixed_asset")
}

model BusinessDocument {
  id           String       @id @default(uuid())
  key          String       @unique
  fileName     String
  fileType     String?
  size         Int?
  documentType DocumentType
  metadata     Json?        @default("{}")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  checkSheet   CheckSheet?
  invoice      Invoice?
  part         Part?
  qcFinding    QcFinding?

  @@map("business_document")
}

model Customer {
  id            String          @id @default(uuid())
  name          String
  email         String
  phone         String
  address       String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  invoices      Invoice[]
  purchaseOrder PurchaseOrder[]

  @@map("customer")
}

model Invoice {
  id              String            @id @default(uuid())
  invoiceNo       String            @unique
  date            DateTime
  poNo            String?
  status          InvoiceStatus     @default(UNPAID)
  dppHargaJual    Decimal           @db.Decimal(15, 0)
  dppNilaiLain    Decimal           @db.Decimal(15, 0)
  ppn             Decimal           @db.Decimal(15, 0)
  total           Decimal           @db.Decimal(15, 0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customerId      String
  createdById     String
  documentId      String?           @unique
  purchaseOrderId String?           @unique
  createdBy       User              @relation(fields: [createdById], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  document        BusinessDocument? @relation(fields: [documentId], references: [id])
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  items           InvoiceItem[]

  @@map("invoice")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  no          Int
  partNo      String?
  description String
  unitPrice   Decimal @db.Decimal(15, 0)
  qty         Decimal @db.Decimal(15, 0)
  qtyUnit     String
  amount      Decimal @db.Decimal(15, 0)
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_item")
}

model PurchaseOrder {
  id         String       @id @default(cuid())
  poNumber   String       @unique
  customerId String
  dueDate    DateTime
  notes      String?
  createdAt  DateTime     @default(now())
  invoice    Invoice?
  jobCards   JobCard?
  lineItems  PoLineItem[]
  customer   Customer     @relation(fields: [customerId], references: [id])

  @@map("purchase_order")
}

model PoLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  partId          String
  quantity        Int
  unitPrice       Decimal       @db.Decimal(15, 0)
  jobList         JobList?
  part            Part          @relation(fields: [partId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("po_line_item")
}

model Part {
  id             String             @id @default(cuid())
  partNo         String             @unique
  description    String
  castingType    CastingType
  createdAt      DateTime           @default(now())
  materialId     String?
  drawingId      String?            @unique
  jobLists       JobList[]
  drawing        BusinessDocument?  @relation(fields: [drawingId], references: [id])
  material       Material?          @relation(fields: [materialId], references: [id])
  materials      PartMaterial[]
  specifications PartSpecification?
  lineItems      PoLineItem[]
  routing        RoutingTemplate?

  @@map("part")
}

model PartMaterial {
  id         String   @id @default(cuid())
  partId     String
  materialId String
  ratio      Decimal  @db.Decimal(5, 2)
  material   Material @relation(fields: [materialId], references: [id])
  part       Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([partId, materialId])
  @@map("part_material")
}

model PartSpecification {
  id            String   @id @default(cuid())
  partId        String   @unique
  length        Decimal? @db.Decimal(10, 2)
  width         Decimal? @db.Decimal(10, 2)
  height        Decimal? @db.Decimal(10, 2)
  weight        Decimal? @db.Decimal(10, 2)
  unit          String   @default("mm")
  tolerance     String?
  surfaceFinish String?
  otherSpecs    Json?    @default("{}")
  part          Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@map("part_specification")
}

model RoutingTemplate {
  id        String        @id @default(cuid())
  partId    String        @unique
  createdAt DateTime      @default(now())
  steps     RoutingStep[]
  part      Part          @relation(fields: [partId], references: [id])

  @@map("routing_template")
}

model RoutingStep {
  id                 String          @id @default(cuid())
  routingTemplateId  String
  stepOrder          Int
  operationName      String
  defaultMachineType String?
  estimatedMinutes   Int?
  defaultMachineId   String?
  operations         Operation[]
  defaultMachine     Machine?        @relation("DefaultMachine", fields: [defaultMachineId], references: [id])
  routing            RoutingTemplate @relation(fields: [routingTemplateId], references: [id])

  @@unique([routingTemplateId, stepOrder])
  @@map("routing_step")
}

model Machine {
  id           String        @id @default(cuid())
  name         String
  machineType  String
  isActive     Boolean       @default(true)
  operations   Operation[]
  defaultSteps RoutingStep[] @relation("DefaultMachine")

  @@map("machine")
}

model JobCard {
  id              String         @id @default(cuid())
  jobNo           String         @unique
  purchaseOrderId String?        @unique
  status          JobCardStatus  @default(PENDING)
  createdById     String
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  createdBy       User           @relation("JobCardCreatedBy", fields: [createdById], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  jobLists        JobList[]

  @@map("job_card")
}

model JobList {
  id           String        @id @default(cuid())
  jobCardId    String
  lineItemId   String?       @unique
  quantity     Int
  status       JobCardStatus @default(PENDING)
  partId       String?
  jobCard      JobCard       @relation(fields: [jobCardId], references: [id])
  lineItem     PoLineItem?   @relation(fields: [lineItemId], references: [id])
  part         Part?         @relation(fields: [partId], references: [id])
  jobMaterials JobMaterial[]
  operations   Operation[]

  @@map("job_list")
}

model JobMaterial {
  id         String   @id @default(cuid())
  jobListId  String
  materialId String
  quantity   Decimal  @db.Decimal(10, 3)
  jobList    JobList  @relation(fields: [jobListId], references: [id])
  material   Material @relation(fields: [materialId], references: [id])

  @@map("job_material")
}

model Operation {
  id            String          @id @default(cuid())
  jobListId     String
  routingStepId String
  stepOrder     Int
  operationName String
  machineId     String?
  operatorId    String?
  status        OperationStatus @default(WAITING)
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  checkSheet    CheckSheet?
  materialsUsed MaterialUsage[]
  jobList       JobList         @relation(fields: [jobListId], references: [id])
  machine       Machine?        @relation(fields: [machineId], references: [id])
  operator      User?           @relation("OperationOperator", fields: [operatorId], references: [id])
  routingStep   RoutingStep     @relation(fields: [routingStepId], references: [id])
  qcLog         QcLog?

  @@unique([jobListId, stepOrder])
  @@map("operation")
}

model QcLog {
  id          String      @id @default(cuid())
  operationId String      @unique
  result      QcResult
  reason      String?
  inspectorId String
  loggedAt    DateTime    @default(now())
  findings    QcFinding[]
  inspector   User        @relation("QcInspector", fields: [inspectorId], references: [id])
  operation   Operation   @relation(fields: [operationId], references: [id])

  @@map("qc_log")
}

model QcFinding {
  id            String            @id @default(cuid())
  qcLogId       String
  category      FindingCategory   @default(OTHER)
  parameter     String
  specification String?
  measuredValue String?
  unit          String?
  description   String?
  isConforming  Boolean           @default(true)
  documentId    String?           @unique
  document      BusinessDocument? @relation(fields: [documentId], references: [id])
  qcLog         QcLog             @relation(fields: [qcLogId], references: [id], onDelete: Cascade)

  @@map("qc_finding")
}

model CheckSheet {
  id          String            @id @default(cuid())
  type        CheckSheetType
  operationId String            @unique
  documentId  String?           @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  document    BusinessDocument? @relation(fields: [documentId], references: [id])
  operation   Operation         @relation(fields: [operationId], references: [id])
  rows        CheckSheetRow[]

  @@map("check_sheet")
}

model CheckSheetRow {
  id            String     @id @default(cuid())
  checkSheetId  String
  parameterName String
  targetValue   String?
  actualValue   String?
  minTolerance  Decimal?   @db.Decimal(10, 4)
  maxTolerance  Decimal?   @db.Decimal(10, 4)
  isPass        Boolean?
  checkSheet    CheckSheet @relation(fields: [checkSheetId], references: [id], onDelete: Cascade)

  @@map("check_sheet_row")
}

/// We could not retrieve columns for the underlying table. Either it has none or you are missing rights to see them. Please check your privileges.
// model CheckSheetConfig {
// @@map("check_sheet_config")
// @@ignore
// }

model Material {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  description      String?
  unit             MaterialUnit
  stockQty         Decimal           @default(0) @db.Decimal(10, 3)
  reorderThreshold Decimal           @db.Decimal(10, 3)
  reorderQty       Decimal           @db.Decimal(10, 3)
  supplierId       String?
  unitCost         Decimal?          @db.Decimal(15, 0)
  createdAt        DateTime          @default(now())
  jobMaterials     JobMaterial[]
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  usages           MaterialUsage[]
  parts            Part[]
  partMaterials    PartMaterial[]
  adjustments      StockAdjustment[]
  stockLedgers     StockLedger[]

  @@map("material")
}

model MaterialUsage {
  id          String    @id @default(cuid())
  operationId String
  materialId  String
  qtyUsed     Decimal   @db.Decimal(10, 3)
  loggedAt    DateTime  @default(now())
  material    Material  @relation(fields: [materialId], references: [id])
  operation   Operation @relation(fields: [operationId], references: [id])

  @@map("material_usage")
}

model StockAdjustment {
  id           String   @id @default(cuid())
  materialId   String
  qty          Decimal  @db.Decimal(10, 3)
  reason       String
  adjustedById String
  adjustedAt   DateTime @default(now())
  adjustedBy   User     @relation("StockAdjustedBy", fields: [adjustedById], references: [id])
  material     Material @relation(fields: [materialId], references: [id])

  @@map("stock_adjustment")
}

model StockLedger {
  id              String                @id @default(cuid())
  materialId      String
  transactionType LedgerTransactionType
  qtyChange       Decimal               @db.Decimal(10, 3)
  balanceAfter    Decimal               @db.Decimal(10, 3)
  reason          String?
  referenceId     String?
  userId          String?
  createdAt       DateTime              @default(now())
  material        Material              @relation(fields: [materialId], references: [id])
  user            User?                 @relation(fields: [userId], references: [id])

  @@map("stock_ledger")
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime   @default(now())
  materials Material[]

  @@map("supplier")
}

enum Role {
  ADMIN
  FINANCE
  EXECUTIVE
  OPERATOR
}

enum AccountType {
  ASSET
  CONTRA_ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum DocumentType {
  INVOICE
  PURCHASE_ORDER
  DELIVERY_NOTE
  OTHER
  CHECK_SHEET
  DRAWING
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIAL
  CANCELLED
}

enum CastingType {
  INVESTMENT
  SAND
}

enum JobCardStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum OperationStatus {
  WAITING
  QUEUED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum QcResult {
  PASS
  REPAIR
  REJECT
}

enum MaterialUnit {
  KG
  GRAM
  LITRE
  PIECE
  METRE
}

enum FindingCategory {
  DIMENSION
  SURFACE
  CHEMICAL
  VISUAL
  FUNCTIONAL
  OTHER
}

enum CheckSheetType {
  MELTING
  FINISHING
}

enum LedgerTransactionType {
  RECEIPT
  ADJUSTMENT
  USAGE
  RETURN
}
